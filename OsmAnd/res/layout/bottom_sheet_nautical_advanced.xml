<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/list_background_color"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="@string/nautical_advanced_calibration_dynamics"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:textStyle="bold" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/safety_lock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="@string/nautical_advanced_lock" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/dividerColor" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/settings_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Vessel Dynamics -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/nautical_advanced_vessel_dynamics"
                android:textAppearance="?attr/textAppearanceCaption"
                android:textColor="?attr/colorAccent"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nautical_advanced_rudder_gain" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_rudder_gain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.5"
                    android:valueTo="5.0"
                    android:stepSize="0.1"
                    android:value="1.0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nautical_advanced_counter_rudder" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_counter_rudder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.0"
                    android:valueTo="10.0"
                    android:stepSize="0.5"
                    android:value="2.0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nautical_advanced_auto_trim" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_auto_trim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:stepSize="0.01"
                    android:value="0.1" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/dividerColor" android:layout_marginBottom="16dp" />

            <!-- Sensor & Hardware -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/nautical_advanced_sensor_hardware"
                android:textAppearance="?attr/textAppearanceCaption"
                android:textColor="?attr/colorAccent"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_compass_calib"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:text="@string/nautical_advanced_compass_wizard"
                app:icon="@drawable/ic_action_direction_compass" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nautical_advanced_filter_sensitivity" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_filter_sensitivity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.0"
                    android:valueTo="10.0"
                    android:stepSize="1.0"
                    android:value="3.0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nautical_advanced_rudder_limit" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_rudder_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="10.0"
                    android:valueTo="45.0"
                    android:stepSize="1.0"
                    android:value="30.0" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/dividerColor" android:layout_marginBottom="16dp" />

            <!-- Safety Thresholds -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/nautical_advanced_safety_thresholds"
                android:textAppearance="?attr/textAppearanceCaption"
                android:textColor="?attr/colorAccent"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nautical_advanced_off_course_threshold" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_off_course"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="5.0"
                    android:valueTo="30.0"
                    android:stepSize="1.0"
                    android:value="15.0" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/nautical_advanced_response_preview"
                android:textAppearance="?attr/textAppearanceCaption"
                android:textColor="?attr/colorAccent"
                android:textStyle="bold" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/pid_preview_chart"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp"
                android:background="?attr/activity_background_color" />

            <Button
                android:id="@+id/btn_reset_defaults"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/nautical_advanced_reset_defaults"
                android:textColor="@color/text_color_negative" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">
        <Button
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nautical_advanced_cancel" />
        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nautical_advanced_apply_save" />
    </LinearLayout>

</LinearLayout>
