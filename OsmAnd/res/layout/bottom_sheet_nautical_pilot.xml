<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/list_background_color"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/pilot_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- Top Handle for Bottom Sheet -->
        <ImageView
            android:id="@+id/bottom_sheet_handle"
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_rounded_handle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription" />

        <!-- 1. Dashboard Header (Mode Toggles + Settings) -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/mode_toggle_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bottom_sheet_handle"
            app:singleSelection="true">

            <Button
                android:id="@+id/btn_mode_compass"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                app:icon="@drawable/ic_action_direction_compass"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp" />

            <Button
                android:id="@+id/btn_mode_wind"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                app:icon="@drawable/ic_action_wind"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp" />

            <Button
                android:id="@+id/btn_mode_route"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                app:icon="@drawable/ic_action_track_16"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp" />

            <Button
                android:id="@+id/btn_mode_stop"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                app:icon="@drawable/ic_action_stop"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <ImageButton
            android:id="@+id/btn_advanced"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/shared_string_settings"
            app:layout_constraintBottom_toBottomOf="@id/mode_toggle_group"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/mode_toggle_group"
            app:srcCompat="@drawable/ic_action_settings"
            app:tint="?attr/icon_color_primary" />

        <!-- 2. Autopilot Head Card (Steering + Control Cluster) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/steering_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="?attr/activity_background_color"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mode_toggle_group"
            app:strokeColor="?attr/divider_color"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="20dp">

                <net.osmand.plus.plugins.nautical.ui.HeadingArcView
                    android:id="@+id/heading_arc_view"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Left Control Column -->
                <LinearLayout
                    android:id="@+id/left_controls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/heading_error_dial"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/heading_error_dial">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_minus_10"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="60dp"
                        android:layout_height="52dp"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="-10"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp"
                        app:strokeColor="?attr/divider_color" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_minus_1"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="-1"
                        android:textSize="15sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="?attr/divider_color" />
                </LinearLayout>

                <net.osmand.plus.plugins.nautical.ui.HeadingErrorDialView
                    android:id="@+id/heading_error_dial"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintEnd_toStartOf="@+id/right_controls"
                    app:layout_constraintStart_toEndOf="@+id/left_controls"
                    app:layout_constraintTop_toBottomOf="@id/heading_arc_view" />

                <!-- Right Control Column -->
                <LinearLayout
                    android:id="@+id/right_controls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/heading_error_dial"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/heading_error_dial">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_plus_10"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="60dp"
                        android:layout_height="52dp"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="+10"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp"
                        app:strokeColor="?attr/divider_color" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_plus_1"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="+1"
                        android:textSize="15sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="?attr/divider_color" />
                </LinearLayout>

                <net.osmand.plus.plugins.nautical.ui.RudderView
                    android:id="@+id/rudder_view"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="32dp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/heading_error_dial" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. Telemetry Pane (3x2 Matrix) -->
        <LinearLayout
            android:id="@+id/telemetry_pane"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/steering_card">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Row 1, Col 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/img_icon_1_1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_action_speed"
                        app:tint="?attr/icon_color_secondary"
                        tools:ignore="ContentDescription" />
                    <TextView
                        android:id="@+id/txt_label_1_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="?attr/text_color_secondary"
                        tools:text="SOG" />
                    <TextView
                        android:id="@+id/txt_value_1_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textStyle="bold"
                        tools:text="6.4 kn" />
                </LinearLayout>

                <!-- Row 1, Col 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/img_icon_1_2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_action_direction_arrow"
                        app:tint="?attr/icon_color_secondary"
                        tools:ignore="ContentDescription" />
                    <TextView
                        android:id="@+id/txt_label_1_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="?attr/text_color_secondary"
                        tools:text="HDG ERR" />
                    <TextView
                        android:id="@+id/txt_value_1_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textStyle="bold"
                        tools:text="2.1°" />
                </LinearLayout>

                <!-- Row 1, Col 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/img_icon_1_3"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_action_direction_compass"
                        app:tint="?attr/icon_color_secondary"
                        tools:ignore="ContentDescription" />
                    <TextView
                        android:id="@+id/txt_label_1_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="?attr/text_color_secondary"
                        tools:text="TARGET" />
                    <TextView
                        android:id="@+id/txt_value_1_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textStyle="bold"
                        tools:text="245°" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Row 2, Col 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/img_icon_2_1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_action_speed"
                        app:tint="?attr/icon_color_secondary"
                        tools:ignore="ContentDescription" />
                    <TextView
                        android:id="@+id/txt_label_2_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="?attr/text_color_secondary"
                        tools:text="STW" />
                    <TextView
                        android:id="@+id/txt_value_2_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textStyle="bold"
                        tools:text="6.2 kn" />
                </LinearLayout>

                <!-- Row 2, Col 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/img_icon_2_2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_action_direction_movement"
                        app:tint="?attr/icon_color_secondary"
                        tools:ignore="ContentDescription" />
                    <TextView
                        android:id="@+id/txt_label_2_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="?attr/text_color_secondary"
                        tools:text="SET/DRFT" />
                    <TextView
                        android:id="@+id/txt_value_2_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textStyle="bold"
                        tools:text="240/0.2" />
                </LinearLayout>

                <!-- Row 2, Col 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/img_icon_2_3"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_action_direction_arrow"
                        app:tint="?attr/icon_color_secondary"
                        tools:ignore="ContentDescription" />
                    <TextView
                        android:id="@+id/txt_label_2_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="?attr/text_color_secondary"
                        tools:text="ROT" />
                    <TextView
                        android:id="@+id/txt_value_2_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textStyle="bold"
                        tools:text="0.5°/s" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
