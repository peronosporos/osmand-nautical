<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/list_background_color"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Zone 1: Command Header (Kill Switch Zone) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/mode_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:text="@string/nautical_mode_stby"
            app:chipBackgroundColor="?attr/activity_background_color" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_standby"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@color/text_color_negative"
                android:text="@string/nautical_disengage_standby"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/standby_progress"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                app:indicatorColor="@android:color/white"
                app:indicatorSize="32dp"
                app:trackColor="#40FFFFFF"
                app:trackThickness="4dp" />
        </FrameLayout>
    </LinearLayout>

    <!-- Zone 2: Navigation Arc (Steering Zone) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="0dp">

        <net.osmand.plus.plugins.nautical.ui.HeadingArcView
            android:id="@+id/heading_arc_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center"
            android:paddingBottom="24dp">

            <Button
                android:id="@+id/btn_minus_1"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="@string/nautical_adjust_minus_1"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btn_plus_1"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="@string/nautical_adjust_plus_1"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <net.osmand.plus.plugins.nautical.ui.RudderView
        android:id="@+id/rudder_view"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp" />

    <!-- Zone 3: Tuning Footer (Environmental Zone) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_advanced"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:alpha="0.4"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:srcCompat="@drawable/ic_action_settings" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/sea_state_toggle_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            app:singleSelection="true">

            <Button
                android:id="@+id/btn_sea_calm"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nautical_sea_calm" />

            <Button
                android:id="@+id/btn_sea_auto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nautical_mode_auto" />

            <Button
                android:id="@+id/btn_sea_heavy"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nautical_sea_heavy" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </RelativeLayout>
</LinearLayout>
