<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/list_background_color">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/pilot_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- 1. Dashboard Header (Mode Toggles + Settings) -->
        <View
            android:id="@+id/header_bg"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:background="?attr/activity_background_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/mode_toggle_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="@id/header_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/header_bg"
            app:singleSelection="true">

            <Button
                android:id="@+id/btn_mode_compass"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                app:icon="@drawable/ic_action_direction_compass"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <Button
                android:id="@+id/btn_mode_wind"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                app:icon="@drawable/ic_action_sail_boat_dark"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <Button
                android:id="@+id/btn_mode_route"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                app:icon="@drawable/ic_action_track_16"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <Button
                android:id="@+id/btn_mode_stop"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:padding="0dp"
                app:icon="@drawable/ic_action_stop"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <ImageButton
            android:id="@+id/btn_advanced"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/shared_string_settings"
            app:layout_constraintBottom_toBottomOf="@id/header_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/header_bg"
            app:srcCompat="@drawable/ic_action_settings" />

        <!-- 2. Steering Command Center (HeadingArcView + HeadingErrorDialView clustered) -->
        <!-- Using Vertical Packed Chain to keep them as a single visual block -->
        <net.osmand.plus.plugins.nautical.ui.HeadingArcView
            android:id="@+id/heading_arc_view"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_marginTop="16dp"
            app:layout_constraintBottom_toTopOf="@+id/heading_error_dial"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header_bg"
            app:layout_constraintVertical_chainStyle="packed" />

        <net.osmand.plus.plugins.nautical.ui.HeadingErrorDialView
            android:id="@+id/heading_error_dial"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="8dp"
            app:layout_constraintBottom_toTopOf="@+id/telemetry_pane"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/heading_arc_view" />

        <!-- 3. Telemetry Pane (3x2 Matrix) -->
        <androidx.gridlayout.widget.GridLayout
            android:id="@+id/telemetry_pane"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="16dp"
            app:columnCount="3"
            app:layout_constraintBottom_toTopOf="@+id/adjustment_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/heading_error_dial">

            <!-- Row 1, Col 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_columnWeight="1">
                <TextView
                    android:id="@+id/txt_label_1_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="?attr/text_color_secondary"
                    tools:text="SOG" />
                <TextView
                    android:id="@+id/txt_value_1_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadline6"
                    android:textStyle="bold"
                    tools:text="6.4 kn" />
            </LinearLayout>

            <!-- Row 1, Col 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_columnWeight="1">
                <TextView
                    android:id="@+id/txt_label_1_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="?attr/text_color_secondary"
                    tools:text="HDG ERR" />
                <TextView
                    android:id="@+id/txt_value_1_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadline6"
                    android:textStyle="bold"
                    tools:text="2.1°" />
            </LinearLayout>

            <!-- Row 1, Col 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_columnWeight="1">
                <TextView
                    android:id="@+id/txt_label_1_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="?attr/text_color_secondary"
                    tools:text="TARGET" />
                <TextView
                    android:id="@+id/txt_value_1_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadline6"
                    android:textStyle="bold"
                    tools:text="245°" />
            </LinearLayout>

            <!-- Row 2, Col 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_columnWeight="1">
                <TextView
                    android:id="@+id/txt_label_2_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="?attr/text_color_secondary"
                    tools:text="STW" />
                <TextView
                    android:id="@+id/txt_value_2_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadline6"
                    android:textStyle="bold"
                    tools:text="6.2 kn" />
            </LinearLayout>

            <!-- Row 2, Col 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_columnWeight="1">
                <TextView
                    android:id="@+id/txt_label_2_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="?attr/text_color_secondary"
                    tools:text="SET/DRFT" />
                <TextView
                    android:id="@+id/txt_value_2_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadline6"
                    android:textStyle="bold"
                    tools:text="240/0.2" />
            </LinearLayout>

            <!-- Row 2, Col 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_columnWeight="1">
                <TextView
                    android:id="@+id/txt_label_2_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="?attr/text_color_secondary"
                    tools:text="ROT" />
                <TextView
                    android:id="@+id/txt_value_2_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadline6"
                    android:textStyle="bold"
                    tools:text="0.5°/s" />
            </LinearLayout>
        </androidx.gridlayout.widget.GridLayout>

        <!-- 4. Adjustment Buttons (Controls) -->
        <LinearLayout
            android:id="@+id/adjustment_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@+id/rudder_view"
            app:layout_constraintTop_toBottomOf="@id/telemetry_pane">

            <Button
                android:id="@+id/btn_minus_10"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="-10"
                android:textSize="16sp"
                app:cornerRadius="32dp" />

            <Button
                android:id="@+id/btn_minus_1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="-1"
                android:textSize="16sp"
                app:cornerRadius="28dp" />

            <Button
                android:id="@+id/btn_plus_1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="+1"
                android:textSize="16sp"
                app:cornerRadius="28dp" />

            <Button
                android:id="@+id/btn_plus_10"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="16dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="+10"
                android:textSize="16sp"
                app:cornerRadius="32dp" />
        </LinearLayout>

        <!-- 5. RudderView (Health Bar at the bottom) -->
        <net.osmand.plus.plugins.nautical.ui.RudderView
            android:id="@+id/rudder_view"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="64dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/adjustment_container" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
