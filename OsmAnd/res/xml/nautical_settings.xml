<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:title="@string/plugin_nautical_name"
    tools:context="net.osmand.plus.plugins.nautical.NauticalSettingsFragment">

    <PreferenceCategory
        android:layout="@layout/preference_category_with_descr"
        android:title="@string/nautical_settings_title" />

    <net.osmand.plus.settings.preferences.EditTextPreferenceEx
        android:key="server_ip"
        android:layout="@layout/preference_with_descr"
        android:title="@string/nautical_server_ip_desc"
        android:dialogTitle="@string/nautical_server_ip_desc" />

    <net.osmand.plus.settings.preferences.EditTextPreferenceEx
        android:key="server_port"
        android:layout="@layout/preference_with_descr"
        android:title="@string/nautical_server_port_desc"
        android:dialogTitle="@string/nautical_server_port_desc" />

    <net.osmand.plus.settings.preferences.SwitchPreferenceEx
        android:key="server_secure"
        android:layout="@layout/preference_with_descr"
        android:title="@string/nautical_server_secure_desc" />

    <PreferenceCategory
        android:layout="@layout/preference_category_with_descr"
        android:title="@string/nautical_advanced_settings" />

    <net.osmand.plus.settings.preferences.SwitchPreferenceEx
        android:key="nautical_show_laylines"
        android:layout="@layout/preference_with_descr"
        android:title="@string/nautical_show_laylines" />

    <net.osmand.plus.settings.preferences.SwitchPreferenceEx
        android:key="nautical_show_wind_shifts"
        android:layout="@layout/preference_with_descr"
        android:title="@string/nautical_show_wind_shifts" />

    <net.osmand.plus.settings.preferences.SwitchPreferenceEx
        android:key="nautical_show_trajectory"
        android:layout="@layout/preference_with_descr"
        android:title="@string/nautical_show_trajectory" />

    <net.osmand.plus.settings.preferences.ListPreferenceEx
        android:key="ais_receive_in_background"
        android:layout="@layout/preference_with_descr"
        android:title="@string/nautical_receive_in_background" />

</PreferenceScreen>
